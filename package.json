{
  "name": "xpr-quests",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:backend": "pnpm --filter @xpr-quests/backend dev",
    "dev:frontend": "pnpm --filter @xpr-quests/frontend dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @xpr-quests/backend drizzle-kit generate",
    "db:migrate": "pnpm --filter @xpr-quests/backend drizzle-kit migrate",
    "db:seed": "pnpm --filter @xpr-quests/backend tsx src/db/seed.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "es5-ext"]
  }
}
