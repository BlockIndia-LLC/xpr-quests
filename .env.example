# Database
DATABASE_URL=postgresql://quests:quests_dev@localhost:5432/xpr_quests

# Redis
REDIS_URL=redis://localhost:6379

# XPR Network
XPR_RPC_ENDPOINT=https://protontestnet.ledgerwise.io
# Must be a Hyperion v2 endpoint (supports /v2/history/get_actions).
# Standard RPC endpoints do NOT work. If unavailable, action polling is disabled gracefully.
XPR_HYPERION_ENDPOINT=https://protontestnet.ledgerwise.io
XPR_NETWORK=testnet
CONTRACT_ACCOUNT=xprquests
ADMIN_ACCOUNTS=prem

# Backend
SERVER_PRIVATE_KEY=
BACKEND_PORT=3000
JWT_SECRET=change-me-in-production

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws
NEXT_PUBLIC_NETWORK=testnet
NEXT_PUBLIC_XPR_RPC=https://protontestnet.ledgerwise.io
NEXT_PUBLIC_CHAIN_ID=71ee83bcf52142d61019d95f9cc5427ba6a0d7ff8accd9e2088ae2abeaf3d3dd
